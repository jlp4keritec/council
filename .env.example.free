# =============================================================================
# LLM Council -- Configuration 100% GRATUITE
# =============================================================================
# A utiliser pour tester le projet sans payer (rate-limited).
#
# Usage :
#   cp .env.example.free .env
#   # Edite la ligne OPENROUTER_API_KEY ci-dessous
#   ./start.sh
#
# RATE LIMITS :
#   - Sans credits : ~200 requetes / jour (= ~20 questions, Council fait 10 appels/Q)
#   - Avec 10$ deposes (non consommes, reste en credit) : ~1000 req/jour = ~100 questions
#
# LIMITATIONS A CONNAITRE :
#   1. Qualite Stage 3 (Chairman) plus faible qu'avec les modeles payants
#      -- les free models sont bons mais en dessous d'Opus/GPT-5.1/Gemini 3 Pro
#      sur la synthese de long contexte raisonnee
#   2. PRIVACY : la plupart des providers de modeles :free LOGGENT les prompts
#      et les reponses pour entrainer leurs modeles. NE PAS UTILISER pour des
#      donnees clients, secrets, ou conformite reglementaire.
#   3. Disponibilite non garantie : les modeles free peuvent etre retires ou
#      voir leurs limites ajustees sans preavis
#   4. Le free router filtre intelligemment pour les capabilities (json_object,
#      tool use, etc.) -- normalement le Stage 2 fonctionnera, mais si tu vois
#      "parse_method: regex_fallback" partout, change pour des modeles nommes.
# =============================================================================

# REQUIS -- Cle OpenRouter (gratuite, pas besoin de credit card initial)
# Cree un compte sur https://openrouter.ai et genere une cle dans /keys
OPENROUTER_API_KEY=sk-or-v1-...

# Optionnel
OPENROUTER_HTTP_REFERER=https://council.mesoutilsagile.com
OPENROUTER_X_TITLE=LLM Council (free tier)

# =============================================================================
# Modeles -- TOUS GRATUITS via le free router OpenRouter
# =============================================================================
# openrouter/free est un meta-router qui choisit automatiquement un modele
# gratuit selon les besoins de la requete (filtre les capabilities requises).
# En appelant 4 fois en parallele, on obtient en pratique 4 modeles differents
# car le router selectionne aleatoirement parmi les free dispo.

COUNCIL_MODELS=openrouter/free,openrouter/free,openrouter/free,openrouter/free

# Chairman : free router aussi. Pour plus de stabilite tu peux nommer un modele
# free specifique a la place (voir la section ALTERNATIVES ci-dessous).
CHAIRMAN_MODEL=openrouter/free

# Generation des titres : free router. Le filtre choisira un petit modele rapide.
TITLE_MODEL=openrouter/free

# =============================================================================
# ALTERNATIVES -- modeles free nommes (pour plus de previsibilite)
# =============================================================================
# Decommente la section qui t'interesse si tu veux specifier les modeles plutot
# que de laisser le router decider. Verifie d'abord les IDs sur :
#   https://openrouter.ai/models?fmt=cards&pricing=free
#
# A jour mai 2026, les top free models avec support structured output incluent :
#   - deepseek/deepseek-r1:free          (raisonnement, 128K context)
#   - qwen/qwen3-coder-480b:free         (262K context, top free coding)
#   - meta-llama/llama-4-maverick:free   (1M context, generalist)
#   - openai/gpt-oss-120b:free           (OpenAI open weights, agentic)
#   - google/gemma-3-27b:free            (Google, compact)
#
# Exemple de config nommee :
# COUNCIL_MODELS=deepseek/deepseek-r1:free,qwen/qwen3-coder-480b:free,meta-llama/llama-4-maverick:free,openai/gpt-oss-120b:free
# CHAIRMAN_MODEL=openrouter/free
# TITLE_MODEL=openrouter/free

# =============================================================================
# Criteres d'evaluation Stage 2 (identique au .env.example)
# =============================================================================
EVAL_CRITERIA=precision factuelle, pertinence par rapport a la question, profondeur d'analyse, clarte de la formulation.

# =============================================================================
# Robustesse Council : fallback pool + minimum de reponses
# =============================================================================
# Si moins de COUNCIL_MIN_RESPONSES modeles ont repondu en Stage 1, le systeme
# essaie automatiquement les modeles de COUNCIL_FALLBACK_POOL en serie.
# Indispensable en mode free car les modeles :free sont volatils.

COUNCIL_MIN_RESPONSES=3
COUNCIL_FALLBACK_POOL=deepseek/deepseek-chat-v3.1:free,qwen/qwen3-235b-a22b:free,openrouter/free,openrouter/free

# =============================================================================
# Reseau / Robustesse (ms) -- timeouts plus longs car free models peuvent etre lents
# =============================================================================
REQUEST_TIMEOUT=240000
TITLE_TIMEOUT=60000
# Plus de retries car les free models renvoient parfois des 429 (rate limit provider)
MAX_RETRIES=4
RETRY_BASE_DELAY=2000

# =============================================================================
# Storage / Serveur (identique au .env.example)
# =============================================================================
DATA_DIR=data/conversations
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5180,http://localhost:3000

# =============================================================================
# Quota daily affiche dans la sidebar
# =============================================================================
# Free tier OpenRouter sans depot : 200 req/jour = ~20 questions/jour (Council fait 10 appels/Q)
# Free tier avec 10$ deposes (qui restent en credit) : 1000 req/jour = ~100 questions
DAILY_QUOTA_QUESTIONS=5
