# =============================================================================
# LLM Council — exemple de fichier .env
# Copie en .env (local) ou .env.production (VPS) et adapte.
# =============================================================================

# OpenRouter — REQUIS
# Obtiens une clé sur https://openrouter.ai et charge des crédits.
OPENROUTER_API_KEY=sk-or-v1-...

# Optionnel : headers visibles dans le dashboard OpenRouter
OPENROUTER_HTTP_REFERER=https://council.mesoutilsagile.com
OPENROUTER_X_TITLE=LLM Council

# =============================================================================
# Modèles
# =============================================================================
# Council : liste CSV des identifiants OpenRouter.
# Vérifie la disponibilité sur https://openrouter.ai/models avant de modifier.
COUNCIL_MODELS=openai/gpt-5.1,google/gemini-3-pro-preview,anthropic/claude-sonnet-4.5,x-ai/grok-4

# Chairman : EXTERNE au council par défaut, pour éviter le biais d'auto-préférence.
# Si le modèle est indisponible, fallback automatique sur le 1er du council.
CHAIRMAN_MODEL=anthropic/claude-opus-4.6

# Modèle léger pour générer les titres de conversation (rapide + cheap)
TITLE_MODEL=google/gemini-2.5-flash

# =============================================================================
# Critères d'évaluation Stage 2
# =============================================================================
# Adapte selon le domaine. Pour AIComply juridique par exemple :
# EVAL_CRITERIA=Exactitude des références citées (articles, décisions), pertinence de la qualification juridique, complétude au regard du droit applicable, clarté du raisonnement.
EVAL_CRITERIA=précision factuelle, pertinence par rapport à la question, profondeur d'analyse, clarté de la formulation.

# =============================================================================
# Robustesse Council : fallback pool + minimum de réponses
# =============================================================================
# Si moins de COUNCIL_MIN_RESPONSES modèles ont répondu en Stage 1, le système
# essaie automatiquement les modèles de COUNCIL_FALLBACK_POOL en série
# jusqu'à atteindre le minimum, ou jusqu'à épuisement du pool.
# Le Chairman bénéficie aussi d'une cascade de fallback (cf. council.js).

COUNCIL_MIN_RESPONSES=3

# Pool CSV. Conseille : mix de free stables + openrouter/free comme dernière chance.
COUNCIL_FALLBACK_POOL=deepseek/deepseek-chat-v3.1:free,qwen/qwen3-235b-a22b:free,openrouter/free,openrouter/free

# =============================================================================
# Analyse méta-cognitive du Chairman
# =============================================================================
# Quand activée, le Chairman produit un JSON {analysis, final_answer} qui
# permet d'afficher 2 onglets côté UI (Synthèse + Analyse du Chairman).
# Quand désactivée, le Chairman renvoie juste la synthèse markdown :
# Stage 3 ~ 30-40% moins coûteux en sortie (utile en mode payant).
# Override possible à la volée via la modal Configuration côté frontend.
CHAIRMAN_ANALYSIS_ENABLED=true

# =============================================================================
# Réseau / Robustesse — TIMEOUTS EN MILLISECONDES
# =============================================================================
REQUEST_TIMEOUT=180000
TITLE_TIMEOUT=30000
MAX_RETRIES=3
RETRY_BASE_DELAY=1500

# =============================================================================
# Storage
# =============================================================================
DATA_DIR=data/conversations

# =============================================================================
# Serveur
# =============================================================================
HOST=0.0.0.0
PORT=8001
LOG_LEVEL=info

# CORS : liste CSV des origines autorisées
# En local : http://localhost:5180,http://localhost:3000
# En prod  : https://council.mesoutilsagile.com
CORS_ORIGINS=http://localhost:5180,http://localhost:3000

# =============================================================================
# Quota daily affiché dans la sidebar
# =============================================================================
# Indicateur visuel du nombre de questions / jour. Au-delà, le bouton "Nouvelle" est désactivé.
# Free tier sans dépôt : 20 (200 req/j d'OpenRouter / ~10 appels par question)
# Free tier avec 10$ déposés : 100
# Mode payant : valeur très haute (10000) pour désactiver l'alerte
DAILY_QUOTA_QUESTIONS=5

# =============================================================================
# Cortex (second cerveau) — bouton « → Cortex »
# =============================================================================
# URL publique de ton serveur Cortex (le /mcp est ajouté automatiquement).
CORTEX_MCP_URL=https://cortex.mesoutilsagile.com
# Token statique MCP de Cortex (le MCP_TOKEN du .env de Cortex). NE PAS committer.
CORTEX_MCP_TOKEN=
# Tags appliqués aux notes (CSV, minuscules, sans accents).
CORTEX_NOTE_TAGS=council,synthese-ia

# =============================================================================
# Multi-utilisateur (v2.12)
# =============================================================================
# Secret pour signer les sessions. Si vide, dérivé de OPENROUTER_API_KEY.
# En multi-user, METS une vraie valeur aléatoire et stable (sinon les sessions
# changent si tu changes la clé partagée). Ex: une longue chaîne aléatoire.
SESSION_SECRET=
# Longueur minimale du mot de passe à l'inscription.
PASSWORD_MIN_LENGTH=8
# Fichier des comptes (laisser par défaut).
USERS_FILE=data/users.json

# =============================================================================
# Cle maitre pour chiffrer les cles OpenRouter par utilisateur (v2.15)
# =============================================================================
# Si vide, on derive d'OPENROUTER_API_KEY. METTRE une vraie valeur aléatoire stable
# en production pour ne PAS perdre l'acces aux cles deja chiffrees si tu changes
# la cle du serveur.
OPENROUTER_KEYS_SECRET=
