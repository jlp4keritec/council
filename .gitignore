# =============================================================================
# .gitignore -- LLM Council (Node.js + React/Vite)
# =============================================================================

# --- Node ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Build outputs ---
dist/
build/
.vite/
*.tsbuildinfo

# --- Environment (NE JAMAIS COMMITER) ---
.env
.env.*
!.env.example

# --- Donnees utilisateur (NE JAMAIS COMMITER) ---
# Conversations, comptes, leaderboard, etc.
data/
backend/data/
*.db
*.db-journal
*.sqlite
*.sqlite-journal

# --- Logs ---
logs/
*.log

# --- Archives de deploy (deploy.zip, backups) ---
*.zip
*.bak
*.tmp
*.tar
*.tar.gz
*.tgz

# --- Deploy / SSH (NE JAMAIS COMMITER) ---
deploy-config.json
*.pem
*.key
id_rsa*
id_ed25519*

# --- IDE / OS ---
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# --- PowerShell scripts d'ops (souvent specifiques machine locale) ---
# Decommenter si tu ne veux PAS commiter tes scripts deploy/diag :
# deploy-*.ps1
# diag-*.ps1
# audit-*.ps1
# upload-*.ps1

# --- Caches divers ---
.cache/
.parcel-cache/
.next/
.nuxt/
